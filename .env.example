# Database connection (TimescaleDB / PostgreSQL)
DATABASE_URL=postgresql://postgres:your_database_password@localhost:5432/fleet_manager

# Server port
PORT=3000

# JWT secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_gmail_app_password

# HTTPS server toggle (development)
ENABLE_HTTPS=false

# Fleet seeding toggle (development only)
ALLOW_SEED=false

# Traccar GPS device server (for future use)
TRACCAR_URL=http://localhost:8082
TRACCAR_USER=admin
TRACCAR_PASS=admin
